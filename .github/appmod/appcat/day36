public class ArrayExample {
    public static void main(String[] args) {
        // 1. Declaration and initialization (Shortcut)
        int[] numbers = {10, 20, 30, 40, 50}; 

        // 2. Declaration with a fixed size (Defaults to 0 for int)
        int[] scores = new int[5]; 
        scores[0] = 85; // Assigning value to index 0

        // 3. Accessing an element (using 0-based index)
        System.out.println("First element: " + numbers[0]); // Output: 10

        // 4. Getting the size of an array
        System.out.println("Array length: " + numbers.length); // Output: 5

        // 5. Looping through elements (Standard for-loop)
        for (int i = 0; i < numbers.length; i++) {
            System.out.print(numbers[i] + " ");
        }
    }
}
