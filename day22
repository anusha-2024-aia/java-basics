public class ReverseNumberLoop {
    public static void main(String[] args) {
        String numStr = "9876";
        String reversedStr = ""; // Start with an empty string
        
        // Loop starting from the last character index, moving backwards to 0
        for (int i = numStr.length() - 1; i >= 0; i--) {
            reversedStr = reversedStr + numStr.charAt(i); 
        }
        
        System.out.println("Original: " + numStr);
        System.out.println("Reversed: " + reversedStr); 
        // Output: 6789
    }
}

