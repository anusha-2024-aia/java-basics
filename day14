public class SumOfNumbers {
    public static void main(String[] args) {
        int sum = 0;
        int n = 10;
        // Loop from 1 to n to calculate the sum
        for (int i = 1; i <= n; i++) {
            sum = sum + i;
        }
        // Print the final result to the console
        System.out.println("The Sum Of " + n + " Numbers is: " + sum);
    }
}
